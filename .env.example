# AutoRecon 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改

# ============== 超时配置 ==============
# 请求总超时（秒）
TIMEOUT_TOTAL=30
# 连接超时（秒）
TIMEOUT_CONNECT=5
# 读取超时（秒）
TIMEOUT_READ=10
# DNS 解析超时（秒）
TIMEOUT_DNS=3

# ============== 并发配置 ==============
# 最大并发数（安全上限 200）
MAX_THREADS=200
# 子域名扫描并发
SUBDOMAIN_THREADS=50
# 端口扫描并发
PORT_THREADS=100
# 目录扫描并发
DIR_THREADS=20

# ============== 网络配置 ==============
# DNS 服务器（逗号分隔）
DNS_SERVERS=8.8.8.8,8.8.4.4,1.1.1.1
# User-Agent
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
# 是否验证 SSL 证书
VERIFY_SSL=true

# ============== 安全配置 ==============
# 是否启用 SSRF 防护
SSRF_PROTECTION=true
# 是否允许访问内网 IP（危险！仅用于内网扫描）
ALLOW_PRIVATE_IPS=false
# 最大请求速率（请求/秒）
MAX_RATE=100
# 最大突发请求数
MAX_BURST=200

# ============== API 认证 ==============
# 启用 API 认证
AUTH_ENABLED=false
# API Keys（逗号分隔）
# 生产环境必须设置！
API_KEYS=your-secret-key-1,your-secret-key-2

# ============== 输出配置 ==============
# 输出目录
OUTPUT_DIR=./reports
# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# 日志文件路径（留空则只输出到控制台）
# LOG_FILE=/var/log/autorecon.log
